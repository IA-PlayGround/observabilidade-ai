# Spectrum Platform — Environment Variables
# Copy to .env and adjust values

# ── Kafka ─────────────────────────────────────────────────────────
KAFKA_BROKERS=kafka:9092
KAFKA_TOPIC_METRICS=otlp.metrics
KAFKA_TOPIC_TRACES=otlp.traces
KAFKA_TOPIC_LOGS=otlp.logs
KAFKA_CONSUMER_GROUP=spectrum-correlation

# ── Redis ─────────────────────────────────────────────────────────
REDIS_ADDR=redis:6379
REDIS_PASSWORD=
REDIS_DB=0

# ── Prometheus ────────────────────────────────────────────────────
PROMETHEUS_URL=http://prometheus:9090
PROMETHEUS_REMOTE_WRITE=http://prometheus:9090/api/v1/write

# ── Tempo ─────────────────────────────────────────────────────────
TEMPO_URL=http://tempo:3200
TEMPO_GRPC=tempo:9095

# ── Loki ──────────────────────────────────────────────────────────
LOKI_URL=http://loki:3100

# ── Grafana ───────────────────────────────────────────────────────
GRAFANA_URL=http://grafana:3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=spectrum

# ── AI / LLM ──────────────────────────────────────────────────────
# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# Default LLM backend: openai | anthropic | local
LLM_BACKEND=openai
LLM_TIMEOUT_SECONDS=30

# ── Auth ───────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production-use-vault
OIDC_ISSUER_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=

# ── API Gateway ────────────────────────────────────────────────────
API_GATEWAY_PORT=8080
API_GATEWAY_HOST=0.0.0.0
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Correlation Engine ─────────────────────────────────────────────
CORRELATION_PORT=8081
CORRELATION_WINDOW_SECONDS=120

# ── AI Engine ──────────────────────────────────────────────────────
AI_ENGINE_PORT=8082

# ── Observability ──────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
OTEL_SERVICE_NAME=spectrum
ENVIRONMENT=development
LOG_LEVEL=debug
