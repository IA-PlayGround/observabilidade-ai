{
  "annotations": { "list": [{ "builtIn": 1, "datasource": { "type": "grafana", "uid": "-- Grafana --" }, "enable": true, "hide": false, "name": "Incident Start", "type": "dashboard", "iconColor": "red", "tags": ["incident"] }] },
  "editable": true,
  "graphTooltip": 2,
  "id": null,
  "links": [],
  "panels": [
    {
      "gridPos": { "h": 4, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "options": { "content": "# Incident Report\n**Service:** $service | **Severity:** $severity | **Status:** $status", "mode": "markdown" },
      "title": "",
      "type": "text"
    },
    {
      "datasource": { "type": "tempo", "uid": "tempo" },
      "gridPos": { "h": 14, "w": 24, "x": 0, "y": 4 },
      "id": 2,
      "options": {},
      "targets": [
        { "datasource": { "type": "tempo", "uid": "tempo" }, "query": "${traceId}", "queryType": "traceql", "refId": "A" }
      ],
      "title": "Root Cause Trace",
      "type": "traces"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "custom": { "fillOpacity": 20, "lineWidth": 2 }, "unit": "percent" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 18 },
      "id": 3,
      "options": { "legend": { "showLegend": true, "placement": "bottom" } },
      "targets": [
        { "expr": "100 * sum(rate(http_server_duration_milliseconds_count{service_name=\"$service\", http_status_code=~\"5..\"}[5m])) by (service_name) / sum(rate(http_server_duration_milliseconds_count{service_name=\"$service\"}[5m])) by (service_name)", "legendFormat": "Error Rate", "refId": "A" }
      ],
      "title": "Error Rate During Incident",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 18 },
      "id": 4,
      "options": { "dedupStrategy": "none", "showTime": true, "sortOrder": "Descending", "wrapLogMessage": true },
      "targets": [
        { "expr": "{service_name=\"$service\"} |= `$traceId` | json", "refId": "A" }
      ],
      "title": "Incident Logs",
      "type": "logs"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "custom": { "fillOpacity": 20, "lineWidth": 2 }, "unit": "ms" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 26 },
      "id": 5,
      "options": { "legend": { "showLegend": true, "placement": "bottom" } },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum(rate(http_server_duration_milliseconds_bucket{service_name=\"$service\"}[5m])) by (le))", "legendFormat": "p95", "refId": "A" },
        { "expr": "histogram_quantile(0.50, sum(rate(http_server_duration_milliseconds_bucket{service_name=\"$service\"}[5m])) by (le))", "legendFormat": "p50", "refId": "B" }
      ],
      "title": "Latency During Incident",
      "type": "timeseries"
    }
  ],
  "refresh": "auto",
  "schemaVersion": 39,
  "tags": ["spectrum", "incident", "alert"],
  "templating": {
    "list": [
      { "current": { "text": "", "value": "" }, "label": "Service", "name": "service", "query": "", "type": "textbox" },
      { "current": { "text": "", "value": "" }, "label": "Trace ID", "name": "traceId", "query": "", "type": "textbox" },
      { "current": { "text": "critical", "value": "critical" }, "label": "Severity", "name": "severity", "query": "critical, high, medium, low", "type": "custom" },
      { "current": { "text": "active", "value": "active" }, "label": "Status", "name": "status", "query": "active, investigating, resolved", "type": "custom" }
    ]
  },
  "time": { "from": "now-3h", "to": "now" },
  "timezone": "browser",
  "title": "Incident Report",
  "uid": "spectrum-incident-report",
  "version": 1
}
